COMPOSE_PROJECT_NAME=7flows
SEVENFLOWS_APP_PORT=8080
SEVENFLOWS_WEB_PORT=3000
SEVENFLOWS_API_PORT=8000
SEVENFLOWS_POSTGRES_PORT=35432
SEVENFLOWS_REDIS_PORT=36379
SEVENFLOWS_MINIO_PORT=39000
SEVENFLOWS_MINIO_CONSOLE_PORT=39001
SEVENFLOWS_SANDBOX_PORT=38194

POSTGRES_DB=sevenflows
POSTGRES_USER=postgres
POSTGRES_PASSWORD=sevenflows

REDIS_PASSWORD=sevenflows

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=sevenflows-local

SANDBOX_API_KEY=sevenflows-sandbox
SANDBOX_ENABLE_NETWORK=true
SANDBOX_WORKER_TIMEOUT=20

NEXT_PUBLIC_API_URL=http://localhost:8000
SEVENFLOWS_DATABASE_URL=postgresql+psycopg://postgres:sevenflows@db:5432/sevenflows
SEVENFLOWS_REDIS_URL=redis://:sevenflows@redis:6379/0
SEVENFLOWS_S3_ENDPOINT=http://minio:9000
SEVENFLOWS_S3_ACCESS_KEY=minioadmin
SEVENFLOWS_S3_SECRET_KEY=minioadmin123
SEVENFLOWS_S3_BUCKET=sevenflows-local
SEVENFLOWS_S3_REGION=us-east-1
SEVENFLOWS_SECRET_KEY=change-me-in-production
