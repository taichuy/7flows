# Production example.
# Keep API_ALLOWED_ORIGINS explicit even in production.
# The default below only allows local console origins as a safe bootstrap value.
# Replace it with the real console origin list before deployment.
# Production will refuse to start if API_ALLOWED_ORIGINS is missing or empty.
API_ENV=production
API_ALLOWED_ORIGINS=http://127.0.0.1:3100,http://localhost:3100
API_DATABASE_URL=postgres://postgres:sevenflows@127.0.0.1:35432/sevenflows
API_REDIS_URL=redis://:sevenflows@127.0.0.1:36379
API_SERVER_ADDR=0.0.0.0:7800
API_COOKIE_NAME=flowse_console_session
API_SESSION_TTL_DAYS=7
BOOTSTRAP_WORKSPACE_NAME=1Flowse
BOOTSTRAP_ROOT_ACCOUNT=root
BOOTSTRAP_ROOT_EMAIL=root@example.com
BOOTSTRAP_ROOT_PASSWORD=change-me
BOOTSTRAP_ROOT_NAME=Root
BOOTSTRAP_ROOT_NICKNAME=Root
