SEVENFLOWS_APP_NAME=7Flows API
SEVENFLOWS_ENV=local
SEVENFLOWS_DEBUG=true
SEVENFLOWS_HOST=0.0.0.0
SEVENFLOWS_PORT=8000
SEVENFLOWS_SECRET_KEY=change-me
SEVENFLOWS_MIGRATION_ENABLED=false

SEVENFLOWS_DATABASE_URL=postgresql+psycopg://postgres:sevenflows@localhost:35432/sevenflows
SEVENFLOWS_REDIS_URL=redis://:sevenflows@localhost:36379/0
SEVENFLOWS_OIDC_ENABLED=true
SEVENFLOWS_OIDC_PROVIDER=zitadel
SEVENFLOWS_OIDC_ISSUER=https://your-zitadel-instance.zitadel.cloud
SEVENFLOWS_OIDC_CLIENT_ID=
SEVENFLOWS_OIDC_CLIENT_SECRET=
SEVENFLOWS_OIDC_REDIRECT_URI=http://127.0.0.1:3100/api/auth/callback
SEVENFLOWS_OIDC_SCOPES=openid profile email
SEVENFLOWS_ZITADEL_SERVICE_USER_TOKEN=7Flows

SEVENFLOWS_S3_ENDPOINT=http://localhost:39000
SEVENFLOWS_S3_ACCESS_KEY=rustfsadmin
SEVENFLOWS_S3_SECRET_KEY=rustfsadmin
SEVENFLOWS_S3_BUCKET=sevenflows-local
SEVENFLOWS_S3_REGION=us-east-1
SEVENFLOWS_S3_USE_SSL=false

SEVENFLOWS_SANDBOX_URL=http://localhost:38194
SEVENFLOWS_SANDBOX_API_KEY=sevenflows-sandbox
SEVENFLOWS_CALLBACK_TICKET_TTL_SECONDS=86400
SEVENFLOWS_CALLBACK_TICKET_MAX_EXPIRED_CYCLES=3
SEVENFLOWS_CALLBACK_TICKET_CLEANUP_BATCH_SIZE=100
SEVENFLOWS_CALLBACK_TICKET_CLEANUP_SCHEDULE_ENABLED=true
SEVENFLOWS_CALLBACK_TICKET_CLEANUP_INTERVAL_SECONDS=300
SEVENFLOWS_WAITING_RESUME_MONITOR_BATCH_SIZE=100
SEVENFLOWS_WAITING_RESUME_MONITOR_SCHEDULE_ENABLED=true
SEVENFLOWS_WAITING_RESUME_MONITOR_INTERVAL_SECONDS=300
SEVENFLOWS_NOTIFICATION_DELIVERY_TIMEOUT_SECONDS=10
SEVENFLOWS_NOTIFICATION_EMAIL_SMTP_HOST=
SEVENFLOWS_NOTIFICATION_EMAIL_SMTP_PORT=587
SEVENFLOWS_NOTIFICATION_EMAIL_SMTP_USERNAME=
SEVENFLOWS_NOTIFICATION_EMAIL_SMTP_PASSWORD=
SEVENFLOWS_NOTIFICATION_EMAIL_FROM_ADDRESS=
SEVENFLOWS_NOTIFICATION_EMAIL_FROM_NAME=7Flows
SEVENFLOWS_NOTIFICATION_EMAIL_USE_SSL=false
SEVENFLOWS_NOTIFICATION_EMAIL_STARTTLS=true
