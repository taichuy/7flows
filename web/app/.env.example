# Local development example.
# App-level requests can keep using the dedicated backend origin, but Scalar "try it"
# should prefer the current frontend origin so the browser can attach same-host cookies.
VITE_API_BASE_URL=http://127.0.0.1:7800
# Optional: override the domain shown and used by the embedded Scalar viewer.
# Leave empty to use the current frontend origin plus the Vite dev proxy.
# VITE_SCALAR_API_BASE_URL=http://127.0.0.1:3100

# API_ENV=development defaults to trusted local development mode:
# - CORS does not require API_ALLOWED_ORIGINS
# - credentialed browser requests from local frontend origins are allowed
API_ENV=development
API_DATABASE_URL=postgres://postgres:1flowbase@127.0.0.1:35432/1flowbase
API_REDIS_URL=redis://:1flowbase@127.0.0.1:36379
API_SERVER_ADDR=0.0.0.0:7800
API_COOKIE_NAME=flowbase_console_session
API_SESSION_TTL_DAYS=7
BOOTSTRAP_WORKSPACE_NAME=1Flowbase
BOOTSTRAP_ROOT_ACCOUNT=root
BOOTSTRAP_ROOT_EMAIL=root@example.com
BOOTSTRAP_ROOT_PASSWORD=change-me
BOOTSTRAP_ROOT_NAME=Root
BOOTSTRAP_ROOT_NICKNAME=Root
