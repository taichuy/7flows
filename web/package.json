{
  "name": "1flowbase-web",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel --filter=@1flowbase/web",
    "dev:app": "pnpm --filter @1flowbase/web dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "node ../scripts/node/run-frontend-workspace-test.js",
    "test:fast": "node ../scripts/node/test-frontend.js fast",
    "coverage:frontend": "node ../scripts/node/verify-coverage.js frontend",
    "verify:full": "node ../scripts/node/test-frontend.js full",
    "runtime-gate": "node ../scripts/node/runtime-gate.js",
    "style-boundary:all-pages": "node ../scripts/node/check-style-boundary.js all-pages",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.24.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "eslint-plugin-testing-library": "^7.2.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "playwright": "^1.59.1",
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.29.0",
    "vite": "^6.2.6",
    "vitest": "^3.1.1"
  }
}
